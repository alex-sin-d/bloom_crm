{
  "name": "bloom-boys-crm",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "importer:build": "tsc -p tsconfig.importer.json",
    "importer:test": "tsc -p tsconfig.importer.json && node --test .importer-dist/scripts/importer/__tests__/*.test.js",
    "importer:validate": "tsc -p tsconfig.importer.json && node .importer-dist/scripts/importer/cli.js validate",
    "importer:dry-run": "tsc -p tsconfig.importer.json && node .importer-dist/scripts/importer/cli.js dry-run",
    "importer:local": "tsc -p tsconfig.importer.json && node .importer-dist/scripts/importer/cli.js import"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.9",
    "postcss": "^8.5.15",
    "supabase": "^2.108.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^6.0.3"
  }
}
