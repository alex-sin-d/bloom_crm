    "lib/crm/activity-timeline.ts",
    "lib/crm/business-days.ts",
    "lib/crm/collapse-preferences.ts",
    "lib/crm/contact-duplicates.ts",
    "lib/crm/contact-logic.ts",
    "lib/crm/data-review-logic.ts",
    "lib/crm/format.ts",
    "lib/crm/organization-logic.ts",
    "lib/crm/outreach-labels.ts",
    "lib/crm/outreach-rules.ts",
    "lib/crm/query-utils.ts",
    "lib/crm/task-logic.ts",
    "lib/crm/types.ts",
    "lib/supabase/database.types.ts"
  ]
}
